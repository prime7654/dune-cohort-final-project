{
  "info": {
    "name": "HappyMeal Menu API",
    "description": "Postman collection for testing the HappyMeal MenuItem and MenuCategory API endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Menu Items",
      "item": [
        {
          "name": "List Menu Items",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/menu-items/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "menu-items",
                ""
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "if (Array.isArray(data) && data.length > 0) {",
                  "    pm.collectionVariables.set(\"menu_item_id\", data[0].id);",
                  "    if (data[0].menu_category && data[0].menu_category.id) {",
                  "        pm.collectionVariables.set(\"menu_category_id\", data[0].menu_category.id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Create Menu Item",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"menu_category_id\": {{menu_category_id}},\n  \"name\": \"Postman Fried Rice\",\n  \"description\": \"Created from Postman\",\n  \"price\": \"2800.00\",\n  \"stock\": 7,\n  \"is_available\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/menu-items/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "menu-items",
                ""
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "if (data.id) {",
                  "    pm.collectionVariables.set(\"menu_item_id\", data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Retrieve Menu Item",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/menu-items/{{menu_item_id}}/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "menu-items",
                "{{menu_item_id}}",
                ""
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Update Menu Item",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"menu_category_id\": {{menu_category_id}},\n  \"name\": \"Postman Fried Rice Deluxe\",\n  \"description\": \"Updated from Postman\",\n  \"price\": \"3000.00\",\n  \"stock\": 5,\n  \"is_available\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/menu-items/{{menu_item_id}}/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "menu-items",
                "{{menu_item_id}}",
                ""
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Delete Menu Item",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/menu-items/{{menu_item_id}}/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "menu-items",
                "{{menu_item_id}}",
                ""
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 204\", function () {",
                  "    pm.response.to.have.status(204);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Menu Categories",
      "item": [
        {
          "name": "List Menu Categories",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/menu-categories/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "menu-categories",
                ""
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "if (Array.isArray(data) && data.length > 0) {",
                  "    pm.collectionVariables.set(\"menu_category_id\", data[0].id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000",
      "type": "string"
    },
    {
      "key": "menu_category_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "menu_item_id",
      "value": "1",
      "type": "string"
    }
  ]
}
